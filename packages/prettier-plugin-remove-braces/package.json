{
    "name": "@1adybug/prettier-plugin-remove-braces",
    "version": "0.0.14",
    "description": "A Prettier plugin that removes unnecessary braces in JavaScript/TypeScript code",
    "keywords": [
        "prettier",
        "plugin",
        "javascript",
        "typescript",
        "code-formatting",
        "braces",
        "arrow-functions"
    ],
    "author": "1adybug <lurongv@qq.com>",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/1adybug/prettier.git"
    },
    "homepage": "https://github.com/1adybug/prettier/tree/main/packages/prettier-plugin-remove-braces",
    "bugs": {
        "url": "https://github.com/1adybug/prettier/issues"
    },
    "type": "module",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.js"
        }
    },
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "files": [
        "dist"
    ],
    "sideEffects": false,
    "scripts": {
        "build": "rslib build",
        "check": "tsc --noEmit",
        "dev": "rslib build --watch",
        "prepublishOnly": "nub run build",
        "test": "nub --test tests/*.test.ts"
    },
    "publishConfig": {
        "access": "public",
        "registry": "https://registry.npmjs.com/"
    },
    "devDependencies": {
        "@rslib/core": "^0.23.2",
        "@types/node": "^24.13.2",
        "typescript": "^6.0.3"
    },
    "peerDependencies": {
        "prettier": "^3.8.0"
    }
}
