{
    "compilerOptions": {
        "lib": ["ES2022"],
        "target": "ES2022",
        "module": "ESNext",
        "rootDir": "./src",
        "outDir": "./dist",
        "noEmit": true,
        "strict": true,
        "skipLibCheck": true,
        "isolatedModules": true,
        "resolveJsonModule": true,
        "moduleResolution": "bundler",
        "useDefineForClassFields": true,
        "allowImportingTsExtensions": true,
        "types": ["node"]
    },
    "include": ["src"]
}
