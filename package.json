{
    "name": "prettier-mono",
    "version": "1.0.0",
    "description": "",
    "keywords": [],
    "author": "",
    "license": "ISC",
    "type": "module",
    "private": true,
    "scripts": {
        "dev": "bun scripts/dev.mjs",
        "r": "pnpm i && pnpm publish -r",
        "cs": "pnpm changeset && pnpm changeset version",
        "format": "prettier --write .",
        "sync": "bun scripts/syncPackage.mjs",
        "postr": "npm run sync",
        "build": "bun scripts/build.mjs",
        "fg": "npm run format && git add . && git commit -m \"✨feature: format\"",
        "lint": "eslint .",
        "prepare": "husky",
        "check": "bun scripts/tsc.mjs"
    },
    "dependencies": {
        "soda-nodejs": "^0.8.9"
    },
    "devDependencies": {
        "@1adybug/eslint": "^0.0.10",
        "@1adybug/prettier": "workspace:*",
        "@changesets/cli": "^2.29.8",
        "@types/node": "catalog:",
        "eslint": "^9.39.3",
        "husky": "^9.1.7",
        "lint-staged": "^17.0.5",
        "prettier": "catalog:",
        "typescript": "^6.0.3"
    },
    "lint-staged": {
        "**/*": "prettier --write --ignore-unknown"
    },
    "specifier": {},
    "workspaces": {
        "packages": [
            "packages/*"
        ],
        "catalog": {
            "@types/node": "^24.10.14",
            "prettier": "^3.8.1"
        }
    }
}
