{
    "name": "prettier-mono",
    "version": "1.0.0",
    "description": "",
    "keywords": [],
    "author": "",
    "license": "ISC",
    "type": "module",
    "private": true,
    "packageManager": "pnpm@11.10.0",
    "scripts": {
        "dev": "nub run --recursive --filter \"@1adybug/*\" --parallel dev",
        "r": "pnpm i && pnpm publish -r",
        "cs": "nub exec changeset && nub exec changeset version",
        "format": "nub exec prettier --write .",
        "sync": "nub scripts/syncPackage.mjs",
        "postr": "nub run sync",
        "build": "nub run --recursive --filter \"@1adybug/*\" build",
        "fg": "nub run format && git add . && git commit -m \"✨feature: format\"",
        "lint": "nub exec eslint .",
        "prepare": "husky",
        "check": "nub run --recursive --filter \"@1adybug/*\" check",
        "test": "nub run --recursive --filter \"@1adybug/*\" --if-present test"
    },
    "devDependencies": {
        "@1adybug/eslint": "^0.0.11",
        "@1adybug/prettier": "workspace:*",
        "@changesets/cli": "^2.29.8",
        "@types/node": "catalog:",
        "eslint": "^9.39.3",
        "husky": "^9.1.7",
        "lint-staged": "^17.0.7",
        "prettier": "catalog:",
        "typescript": "^6.0.3"
    },
    "lint-staged": {
        "**/*": "prettier --write --ignore-unknown"
    },
    "specifier": {},
    "workspaces": {
        "packages": [
            "packages/*"
        ],
        "catalog": {
            "@types/node": "^24.10.14",
            "prettier": "^3.8.1"
        }
    }
}
